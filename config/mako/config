# mako notification daemon, Kanagawa Wave theme.
# Palette mirrors config/alacritty/themes/kanagawa-wave.toml.

font=Hack Nerd Font 11
background-color=#1f1f28f0
text-color=#dcd7ba
border-color=#7e9cd8
border-size=2
border-radius=10
progress-color=over #2d4f67

padding=12
margin=10
width=360
height=140
icons=1
max-icon-size=48
default-timeout=5000
anchor=top-right
layer=overlay

[urgency=low]
border-color=#727169
default-timeout=3000

[urgency=normal]
border-color=#7e9cd8

[urgency=critical]
border-color=#e82424
default-timeout=0
